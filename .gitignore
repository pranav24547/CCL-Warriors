# ============================================
# CCL Warriors — .gitignore
# ============================================

# ---- Python virtual environments ----
venv/
.venv/
env/
__pycache__/
*.pyc
*.pyo
*.pyd

# ---- Large binary data files ----
# Excel datapacks (competition-provided, not our code)
*.xlsx

# PowerPoint presentations (large binaries)
*.pptx

# ---- Generated output files ----
# These are regenerated by running the Python scripts
*_output.txt
*_output.csv
*output*.txt
forecast_run_output.txt
comparison_output.txt

# Generated data files
forecast_data.json
forecast_data_new.json
dashboard_data_minified.json
forecast_output_new.csv

# Prediction output text files (regenerated by scripts)
CCL_FY26_Q2_Forecast_Predictions.txt
CCL_Predictions_utf8.txt

# ---- Generated HTML files ----
# Dashboards and guides (generated, not source code)
forecast_dashboard.html
forecasting_step_by_step_guide.html
plan_coherence_audit.html
github_readme_guide.html

# ---- Old/superseded working directories ----
# Phase 1 working folders (superseded by phase 2 evolution)
New folder v1/
New folder v2/New folder v1/

# ---- Local runner scripts ----
run.bat

# ---- OS and editor files ----
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.vscode/
.idea/

# ---- Misc generated/temp files ----
new_data_analysis.txt
data_analysis.txt
ppt_text_output.txt
ppt_text_utf8.txt
deep_analysis_full_utf8.txt
extract_pptx_output.txt

# Large generated analysis outputs (regenerated by scripts)
deep_analysis_full.txt
v5_vs_v6_verification.txt
deep_audit*_output.txt
deep_output.txt
forensi*_output.txt
